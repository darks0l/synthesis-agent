# ── Synthesis Agent Configuration ──
# Copy to .env and fill in your values.
# Environment variables override .env values.

# ── Required ──
# WALLET_KEY_FILE=.keys/deployer.txt     # Path to file containing your private key

# ── Chain ──
# BASE_RPC=https://mainnet.base.org      # Base chain RPC (default)

# ── LLM Providers (at least one recommended, falls back to heuristic) ──
# BANKR_API_KEY=bk_xxx                   # Bankr LLM Gateway (primary, closes economic loop)
# OPENAI_API_KEY=sk-xxx                  # OpenAI (fallback)
# ANTHROPIC_API_KEY=sk-ant-xxx           # Anthropic (fallback)
# OPENROUTER_API_KEY=sk-or-xxx           # OpenRouter (fallback)
# OLLAMA_URL=http://localhost:11434      # Local Ollama (free fallback)
# OLLAMA_MODEL=qwen3.5:latest

# ── Uniswap ──
# UNISWAP_API_KEY=xxx                    # Uniswap Developer Platform API key

# ── AgentMail ──
# AGENTMAIL_API_KEY=xxx                  # AgentMail API key for inter-agent communication
# AGENTMAIL_INBOX=agent@agentmail.to     # Your inbox (auto-created if unset)

# ── Spending Limits ──
# MAX_PER_TX=2.0                         # Max USDC per swap (default: 2.0)
# MAX_DAILY=20.0                         # Max USDC per day (default: 20.0)
# SCAN_INTERVAL=60000                    # Scan interval in ms (default: 60000)

# ── Contracts (deploy your own or use defaults) ──
# SPENDING_POLICY=0x...                  # AgentSpendingPolicy contract address
# SYNTHESIS_JOBS_ADDRESS=0x...           # ERC-8183 SynthesisJobs contract address

# ── Virtuals ACP v2 (optional — cross-post jobs to Virtuals agent network) ──
# VIRTUALS_SESSION_KEY_ID=xxx            # Session entity key from app.virtuals.io/acp/join
# VIRTUALS_AGENT_WALLET=0x...            # Override agent wallet (defaults to main wallet)
# VIRTUALS_RPC_URL=https://...           # Custom RPC (defaults to BASE_RPC)

# ── Cards ──
# CARDS_API=https://acp.darksol.net/cards
